{
  "manifest_version": 3,
  "name": "AtCoder Pastel Theme",
  "version": "0.1.2",
  "description": "Applies a soft pastel color theme to AtCoder pages.",
  "content_scripts": [
    {
      "matches": [
        "https://atcoder.jp/*",
        "https://*.contest.atcoder.jp/*",
        "http://*.contest.atcoder.jp/*"
      ],
      "css": ["theme.css"],
      "run_at": "document_start"
    }
  ]
}
