{
  "manifest_version": 3,
  "name": "AtCoder Sample Downloader",
  "version": "0.1.0",
  "description": "Adds a button to AtCoder task pages for downloading sample inputs and outputs as a ZIP file.",
  "content_scripts": [
    {
      "matches": [
        "https://atcoder.jp/contests/*/tasks/*",
        "https://*.contest.atcoder.jp/tasks/*",
        "http://*.contest.atcoder.jp/tasks/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
